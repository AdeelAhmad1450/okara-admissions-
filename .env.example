# ---------------------------------------------------------------------------
# Okara WhatsApp Admissions Platform — backend environment
# Copy to .env and fill in. Most of these can ALSO be set later from the
# dashboard Settings page (they are stored in the database). Env values are
# only used to bootstrap the first run.
# ---------------------------------------------------------------------------

# --- Security (set these for production) ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# First dashboard login (created on first startup)
ADMIN_EMAIL=admin@okara.superior.edu.pk
ADMIN_PASSWORD=OkaraAdmin@2026

# --- Database (SQLite by default; no setup needed) ---
# For Postgres use e.g. postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./okara_admissions.db

# --- CORS: your dashboard URL(s), comma-separated. * allows all (dev only). ---
CORS_ORIGINS=*

# --- WhatsApp Cloud API (or add these from the dashboard Settings page) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=okara-verify-2026
WHATSAPP_APP_SECRET=
GRAPH_API_VERSION=v21.0

# --- AI provider ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Voice notes (speech-to-text + text-to-speech). Need the OpenAI key above. ---
VOICE_REPLIES=on
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- Business identity ---
BUSINESS_NAME=Superior University Okara Campus
DEFAULT_LANGUAGE=en
